    <texture file="stove_metal.png" name="tex-stove_metal" type="2d"/>
    <material name="stove_metal_mat" reflectance="0.5" texrepeat="1 1" texture="tex-stove_metal" texuniform="false" shininess="1.0"/>
    <mesh file="stove_knob_button_vis.msh" name="stove_knob_button_vis" scale="1.0 1.0 1.0"/>
    <mesh file="burnerplate.stl" name="burnerplate" scale="0.55 0.55 0.45"/>

    <!-- (table material defined above) -->
  </asset>

