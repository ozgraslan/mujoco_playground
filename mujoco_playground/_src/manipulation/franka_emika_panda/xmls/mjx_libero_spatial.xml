<mujoco model="panda libero spatial">
  <include file="mjx_panda.xml"/>

  <statistic center="0 0 0.4" extent="1"/>
  <!-- <size njmax="100000" nconmax="512" nstack="1000000"/> -->

  <option timestep="0.005" iterations="10" ls_iterations="16" integrator="implicitfast">
    <flag eulerdamp="disable"/>
  </option>

  <default>
    <!-- Stiff global contacts to prevent implicitfast from squishing/wobbling -->
    <geom solref="0.002 1" solimp="0.95 0.99 0.001"/>
  </default>

  <custom>
    <numeric data="512" name="max_contact_points"/>
  </custom>

  <visual>
    <headlight diffuse=".5 .5 .5" ambient=".1 .1 .1" specular="0.5 0.5 0.5"/>
    <rgba force="1 0 0 1"/>
    <global azimuth="-40" elevation="-30"/>
    <map force="0.01"/>
    <quality shadowsize="8192"/>
    <scale contactwidth="0.075" contactheight="0.025" forcewidth="0.05" com="0.05" framewidth="0.01" framelength="0.2"/>
  </visual>

  <asset>
    <!-- LIBERO scene textures -->
    <texture builtin="gradient" height="256" rgb1=".9 .9 1." rgb2=".2 .3 .4" type="skybox" width="256"/>
    <texture file="libero_floor_tile.png" type="2d" name="groundplane"/>
    <material name="groundplane" reflectance="0.0" shininess="0.0" specular="0.0" texrepeat="3 3" texture="groundplane" texuniform="true"/>
    <!-- Table texture: type="cube" matches LIBERO's cubemap projection on box geom -->
    <texture file="libero_wood_table.png" type="cube" name="tex-table"/>
    <material name="table_texture" reflectance="0.0" shininess="0.0" specular="0.2" texrepeat="1 1" texture="tex-table"/>
    <!-- Table legs -->
    <texture file="libero_wood_table_legs.png" type="cube" name="tex-table-legs"/>
    <material name="table_legs" reflectance="0.8" shininess="0.8" texrepeat="1 1" texture="tex-table-legs"/>
    <texture file="libero_wall_plaster.png" type="2d" name="tex-wall"/>
    <material name="walls_mat" reflectance="0.0" shininess="0.1" specular="0.8" texrepeat="3 3" texture="tex-wall" texuniform="true"/>

    <!-- Akita Black Bowl -->
    <texture file="bowl_texture.png" name="tex-akita_black_bowl" type="2d"/>
    <material name="akita_black_bowl" reflectance="0.5" texrepeat="1 1" texture="tex-akita_black_bowl" texuniform="false"/>
    <mesh file="akita_black_bowl_vis.msh" name="akita_black_bowl_vis" scale="0.7 0.7 0.7"/>

    <!-- Plate -->
    <texture file="plate_texture.png" name="tex-plate" type="2d"/>
    <material name="plate_mat" reflectance="0.5" texrepeat="1 1" texture="tex-plate" texuniform="false"/>
    <mesh file="plate_vis.msh" name="plate_vis" scale="0.5 0.5 0.5"/>

    <!-- Cookies -->
    <texture file="cookies_texture_map.png" name="tex-cookies" type="2d"/>
    <material name="cookies_mat" reflectance="0.5" texrepeat="1 1" texture="tex-cookies" texuniform="false"/>
    <mesh file="cookies_vis.msh" name="cookies_vis" scale="0.005 0.005 0.005"/>

    <!-- Glazed Rim Porcelain Ramekin -->
    <texture file="ramekin_texture.png" name="tex-ramekin" type="2d"/>
    <material name="ramekin_mat" reflectance="0.5" texrepeat="1 1" texture="tex-ramekin" texuniform="false"/>
    <mesh file="ramekin_vis.msh" name="ramekin_vis" scale="1.0 1.0 1.0"/>

    <!-- Wooden Cabinet -->
    <texture file="cabinet_dark_fine_wood.png" name="tex-wooden_cabinet" type="2d"/>
    <texture file="cabinet_metal.png" name="tex-wooden_cabinet_handle" type="2d"/>
    <material name="wooden_cabinet_base_mat" reflectance="0.3" texrepeat="1 1" texture="tex-wooden_cabinet" texuniform="true"/>
    <material name="wooden_cabinet_top_mat" reflectance="0.3" texrepeat="1 1" texture="tex-wooden_cabinet" texuniform="true"/>
    <material name="wooden_cabinet_top_handle_mat" reflectance="0.5" texrepeat="1 1" texture="tex-wooden_cabinet_handle" texuniform="true"/>
