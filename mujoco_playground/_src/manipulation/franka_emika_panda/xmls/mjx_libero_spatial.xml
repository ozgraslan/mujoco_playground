    <material name="wooden_cabinet_bottom_handle_mat" reflectance="0.5" texrepeat="1 1" texture="tex-wooden_cabinet_handle" texuniform="true"/>
    <mesh file="wooden_cabinet_base_vis.msh" name="wooden_cabinet_base_vis" scale="0.05 0.05 0.05"/>
    <mesh file="wooden_cabinet_top_vis.msh" name="wooden_cabinet_top_vis" scale="0.05 0.05 0.05"/>
