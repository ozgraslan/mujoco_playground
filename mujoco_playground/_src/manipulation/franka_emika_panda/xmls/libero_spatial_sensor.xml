<mujoco>
  <sensor>
    <!-- Table-to-hand collision sensors -->
    <contact name="left_finger_pad_table_found" geom1="left_finger_pad" geom2="table_collision" reduce="mindist" num="1" data="found"/>
    <contact name="right_finger_pad_table_found" geom1="right_finger_pad" geom2="table_collision" reduce="mindist" num="1" data="found"/>
    <contact name="hand_capsule_table_found" geom1="hand_capsule" geom2="table_collision" reduce="mindist" num="1" data="found"/>
    <!-- Bowl-to-hand contact sensor (using base geom of concave bowl) -->
    <contact name="bowl1_hand_found" geom1="bowl1_g36" geom2="hand_capsule" reduce="mindist" num="1" data="found"/>
  </sensor>
</mujoco>
